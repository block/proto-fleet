POST {{host}}/fleetmanagement.v1.FleetManagementService/CreatePool
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{
  "pool_config": {
    "url": "https://example.xyz",
    "username": "bob",
    "password": "secret",
    "pool_name": "backup"
  }
}

