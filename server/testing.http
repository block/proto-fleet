@host = http://localhost:4000

### Run health check
GET {{host}}/health

### Onboarding: Create Admin User
POST {{host}}/onboarding.v1.OnboardingService/CreateAdminLogin
Content-Type: application/json

{
  "username": "admin",
  "password": "proto"
}

### Authenticate
# @name authenticate
POST {{host}}/auth.v1.AuthService/Authenticate
Content-Type: application/json

{
  "username": "admin",
  "password": "proto"
}

# After running Authenticate, copy the fleet_session value from the Set-Cookie
# response header and paste it below
#
@session_cookie = "b8e99f98bd9a7089d197604a329a69fa5a3317d17839a167c2ac7e1efcb4d5bb"

### Run mdns discovery
POST {{host}}/pairing.v1.PairingService/Discover
Content-Type: application/grpc+json
Cookie: fleet_session={{session_cookie}}

{
  "mdns": {
    "service_type": "_http._tcp",
    "domain": "fleet_fleet-network.",
    "timeout_seconds": 15
  }
}

### Run nmap discovery

POST {{host}}/pairing.v1.PairingService/Discover
Content-Type: application/grpc+json
Cookie: fleet_session={{session_cookie}}

{
  "nmap": {
    "target": "192.168.2.0/24",
    "ports": [
      "2121"
    ],
    "fast_scan": false
  }
}

### Run ip range discovery

POST {{host}}/pairing.v1.PairingService/Discover
Content-Type: application/grpc+json
Cookie: fleet_session={{session_cookie}}

{
  "ip_range": {
    "start_ip": "10.0.0.248",
    "end_ip": "10.0.0.250",
    "ports": [
      "2121"
    ]
  }
}

### Run ip list discovery

POST {{host}}/pairing.v1.PairingService/Discover
Content-Type: application/grpc+json
Cookie: fleet_session={{session_cookie}}

{
  "ip_list": {
    "ip_addresses": [ "mms-1", "mms-2", "miner-1.miner.fleetdev.proto.xyz", "miner-2.miner.fleetdev.proto.xyz", "miner-3.miner.fleetdev.proto.xyz" ],
    "ports": [
      "2121"
    ]
  }
}

### run pairing query

POST {{host}}/pairing.v1.PairingService/Pair
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{
  "device_identifiers": ["c9ea3eea-60b6-414f-9207-88bf3a1154d2", "eb6993d9-85c4-4ed9-865b-7833aac82af4" ]
}

### list unpaired devices

POST {{host}}/fleetmanagement.v1.FleetManagementService/ListUnpairedDevices
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{
  "page_size": 10
}

### list paired miner state snapshots

POST {{host}}/fleetmanagement.v1.FleetManagementService/ListMinerStateSnapshots
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{
  "page_size": 10
}

### stream miner updates

POST {{host}}/fleetmanagement.v1.FleetManagementService/StreamMinerUpdates HTTP/2
Content-Type: application/grpc+json; charset=utf-8
Accept: application/grpc+json
Cookie: fleet_session={{session_cookie}}

{
  "device_identifiers": ["eb6993d9-85c4-4ed9-865b-7833aac82af4", "c9ea3eea-60b6-414f-9207-88bf3a1154d2"],
  "measurement_types": [1, 2, 3, 4],
  "include_status_updates": true,
  "heartbeat_interval_seconds": 5
}

### Run network info

POST {{host}}/networkinfo.v1.NetworkInfoService/GetNetworkInfo
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{

}

