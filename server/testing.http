### Onboarding: GetFleetOnboardingStatus
POST {{host}}/onboarding.v1.OnboardingService/GetFleetOnboardingStatus
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{

}

### Error Query: Query errors
# Customize these variables to filter results:
# result_view: RESULT_VIEW_ERROR (flat), RESULT_VIEW_DEVICE (by device), RESULT_VIEW_COMPONENT (by component)
# severities: SEVERITY_CRITICAL, SEVERITY_MAJOR, SEVERITY_MINOR, SEVERITY_INFO
# component_types: COMPONENT_TYPE_PSU, COMPONENT_TYPE_HASH_BOARD, COMPONENT_TYPE_FAN, COMPONENT_TYPE_CONTROL_BOARD
@result_view = RESULT_VIEW_ERROR
@filter_severities = ["SEVERITY_CRITICAL", "SEVERITY_MAJOR"]
@filter_component_types = []
@filter_device_ids = []
@include_closed = false

POST {{host}}/errors.v1.ErrorQueryService/Query
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{
  "result_view": "{{result_view}}",
  "filter": {
    "simple": {
      "severities": {{filter_severities}},
      "component_types": {{filter_component_types}},
      "device_ids": {{filter_device_ids}}
    },
    "include_closed": {{include_closed}}
  },
  "page_size": 50
}

### Error Query: Get single error by ID
POST {{host}}/errors.v1.ErrorQueryService/GetError
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{
  "error_id": "01JDEXAMPLE123456789"
}

### Error Query: List all canonical miner errors
POST {{host}}/errors.v1.ErrorQueryService/ListMinerErrors
Content-Type: application/json
Cookie: fleet_session={{session_cookie}}

{
}

### Error Query: Watch for real-time error updates (streaming)
# Uses the same filter variables as Query above
POST {{host}}/errors.v1.ErrorQueryService/Watch HTTP/2
Content-Type: application/grpc+json; charset=utf-8
Accept: application/grpc+json
Cookie: fleet_session={{session_cookie}}

{
  "filter": {
    "simple": {
      "severities": {{filter_severities}},
      "component_types": {{filter_component_types}},
      "device_ids": {{filter_device_ids}}
    },
    "include_closed": {{include_closed}}
  }
}
