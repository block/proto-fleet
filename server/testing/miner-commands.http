@host = http://localhost:4000

### Authenticate
# @name authenticate
POST {{host}}/auth.v1.AuthService/Authenticate
Content-Type: application/json

{
  "username": "protofleet",
  "password": "protofleet"
}

###
@session_cookie = {{authenticate.response.headers.Set-Cookie}}

# Device selector examples:
# By device list:  "device_selector": { "include_devices": { "device_identifiers": ["id1", "id2"] } }
# By filter:       "device_selector": { "all_devices": { "device_status": ["DEVICE_STATUS_ONLINE"] } }

### Reboot
POST {{host}}/minercommand.v1.MinerCommandService/Reboot
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  }
}

### Stop mining
POST {{host}}/minercommand.v1.MinerCommandService/StopMining
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  }
}

### Start mining
POST {{host}}/minercommand.v1.MinerCommandService/StartMining
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
