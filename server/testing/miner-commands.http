### Update miner password
POST {{host}}/minercommand.v1.MinerCommandService/UpdateMinerPassword
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  },
  "new_password": "newminerpass",
  "current_password": "currentminerpass",
  "user_username": "protofleet",
  "user_password": "protofleet"
}

### Check command capabilities
POST {{host}}/minercommand.v1.MinerCommandService/CheckCommandCapabilities
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "command_type": "COMMAND_TYPE_REBOOT",
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  }
}

### Stream command batch updates
POST {{host}}/minercommand.v1.MinerCommandService/StreamCommandBatchUpdates HTTP/2
Content-Type: application/grpc+json; charset=utf-8
Accept: application/grpc+json
Cookie: {{session_cookie}}

{
  "batch_identifier": "TODO_REPLACE_WITH_BATCH_ID"
}

