### Set cooling mode
POST {{host}}/minercommand.v1.MinerCommandService/SetCoolingMode
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  },
  "mode": "COOLING_MODE_AIR_COOLED"
}

### Set power target
POST {{host}}/minercommand.v1.MinerCommandService/SetPowerTarget
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  },
  "performance_mode": "PERFORMANCE_MODE_MAXIMUM_HASHRATE"
}

### Update mining pools (using fleet pool IDs)
POST {{host}}/minercommand.v1.MinerCommandService/UpdateMiningPools
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  },
  "default_pool": {
    "pool_id": "1"
  },
  "backup_1_pool": {
    "pool_id": "2"
  },
  "user_username": "protofleet",
  "user_password": "protofleet"
}

### Update mining pools (using raw pool info)
POST {{host}}/minercommand.v1.MinerCommandService/UpdateMiningPools
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  },
  "default_pool": {
    "raw_pool": {
      "url": "stratum+tcp://pool.example.com:3333",
      "username": "wallet.worker1",
      "password": "x"
    }
  },
  "user_username": "protofleet",
  "user_password": "protofleet"
}

