@host = http://localhost:4000

### Authenticate
# @name authenticate
POST {{host}}/auth.v1.AuthService/Authenticate
Content-Type: application/json

{
  "username": "protofleet",
  "password": "protofleet"
}

###
@session_cookie = {{authenticate.response.headers.Set-Cookie}}

### Logout
POST {{host}}/auth.v1.AuthService/Logout
Content-Type: application/json
Cookie: {{session_cookie}}

{}

### Update password
POST {{host}}/auth.v1.AuthService/UpdatePassword
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "current_password": "protofleet",
  "new_password": "newpassword"
}

### Update username
POST {{host}}/auth.v1.AuthService/UpdateUsername
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "username": "newadmin"
}

### Get user audit info
POST {{host}}/auth.v1.AuthService/GetUserAuditInfo
Content-Type: application/json
Cookie: {{session_cookie}}

{}

### Create user (Super Admin only)
POST {{host}}/auth.v1.AuthService/CreateUser
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "username": "operator1"
}

### List users (Super Admin only)
POST {{host}}/auth.v1.AuthService/ListUsers
Content-Type: application/json
Cookie: {{session_cookie}}

{}

### Reset user password (Super Admin only)
POST {{host}}/auth.v1.AuthService/ResetUserPassword
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "user_id": "TODO_REPLACE_WITH_USER_ID"
}

### Deactivate user (Super Admin only)
POST {{host}}/auth.v1.AuthService/DeactivateUser
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "user_id": "TODO_REPLACE_WITH_USER_ID"
}
