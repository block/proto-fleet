@host = http://localhost:4000

### Authenticate
# @name authenticate
POST {{host}}/auth.v1.AuthService/Authenticate
Content-Type: application/json

{
  "username": "protofleet",
  "password": "protofleet"
}

###
@session_cookie = {{authenticate.response.headers.Set-Cookie}}

### Get combined metrics (all devices, fixed 1-hour window)
POST {{host}}/telemetry.v1.TelemetryService/GetCombinedMetrics
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "all_devices": true
  },
  "measurement_types": [
    "MEASUREMENT_TYPE_HASHRATE",
    "MEASUREMENT_TYPE_TEMPERATURE",
    "MEASUREMENT_TYPE_POWER",
    "MEASUREMENT_TYPE_EFFICIENCY"
  ],
  "aggregations": [
    "AGGREGATION_TYPE_AVERAGE",
    "AGGREGATION_TYPE_MIN",
    "AGGREGATION_TYPE_MAX"
  ],
  "granularity": "60s",
  "start_time": "2025-01-01T00:00:00Z",
  "end_time": "2025-01-01T01:00:00Z",
  "page_size": 100
}

### Get combined metrics (specific devices)
POST {{host}}/telemetry.v1.TelemetryService/GetCombinedMetrics
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "device_list": {
      "device_ids": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  },
  "measurement_types": ["MEASUREMENT_TYPE_HASHRATE"],
  "aggregations": ["AGGREGATION_TYPE_AVERAGE"],
  "granularity": "300s",
  "start_time": "2025-01-01T00:00:00Z",
  "end_time": "2025-01-01T01:00:00Z"
}

### Stream combined metric updates (real-time dashboard)
POST {{host}}/telemetry.v1.TelemetryService/StreamCombinedMetricUpdates HTTP/2
Content-Type: application/grpc+json; charset=utf-8
Accept: application/grpc+json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "all_devices": true
  },
  "metrics": [
    "MEASUREMENT_TYPE_HASHRATE",
    "MEASUREMENT_TYPE_TEMPERATURE",
    "MEASUREMENT_TYPE_POWER",
    "MEASUREMENT_TYPE_EFFICIENCY"
  ],
  "aggregations": [
    "AGGREGATION_TYPE_AVERAGE",
    "AGGREGATION_TYPE_MIN",
    "AGGREGATION_TYPE_MAX"
  ],
  "granularity": "60s",
  "update_interval": "10s",
  "connection_id": "test-tab-1"
}
