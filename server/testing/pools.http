@host = http://localhost:4000

### Authenticate
# @name authenticate
POST {{host}}/auth.v1.AuthService/Authenticate
Content-Type: application/json

{
  "username": "protofleet",
  "password": "protofleet"
}

###
@session_cookie = {{authenticate.response.headers.Set-Cookie}}

### List pools
POST {{host}}/pools.v1.PoolsService/ListPools
Content-Type: application/json
Cookie: {{session_cookie}}

{}

### Create pool
POST {{host}}/pools.v1.PoolsService/CreatePool
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "pool_config": {
    "url": "stratum+tcp://pool.example.com:3333",
    "username": "wallet_address.worker1",
    "password": "x",
    "pool_name": "Primary Pool"
  }
}

### Update pool
POST {{host}}/pools.v1.PoolsService/UpdatePool
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "pool_id": "1",
  "pool_name": "Updated Pool Name",
  "url": "stratum+tcp://pool2.example.com:3333",
  "username": "wallet_address.worker2"
}

### Delete pool
POST {{host}}/pools.v1.PoolsService/DeletePool
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "pool_id": "1"
}

### Validate pool connection
POST {{host}}/pools.v1.PoolsService/ValidatePool
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "url": "stratum+tcp://pool.example.com:3333",
  "username": "wallet_address.worker1",
  "timeout": "30s"
}
