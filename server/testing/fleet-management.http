@host = http://localhost:4000

### Authenticate
# @name authenticate
POST {{host}}/auth.v1.AuthService/Authenticate
Content-Type: application/json

{
  "username": "protofleet",
  "password": "protofleet"
}

###
@session_cookie = {{authenticate.response.headers.Set-Cookie}}

### List miner state snapshots (paired devices)
POST {{host}}/fleetmanagement.v1.FleetManagementService/ListMinerStateSnapshots
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "page_size": 10,
  "filter": {
    "pairing_statuses": ["PAIRING_STATUS_PAIRED"]
  }
}

### List miner state snapshots (unpaired devices)
POST {{host}}/fleetmanagement.v1.FleetManagementService/ListMinerStateSnapshots
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "page_size": 10,
  "filter": {
    "pairing_statuses": ["PAIRING_STATUS_UNPAIRED"]
  }
}

### List miner state snapshots (by collection)
POST {{host}}/fleetmanagement.v1.FleetManagementService/ListMinerStateSnapshots
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "page_size": 10,
  "filter": {
    "group_ids": [1]
  }
}

### List miner state snapshots (with sort)
POST {{host}}/fleetmanagement.v1.FleetManagementService/ListMinerStateSnapshots
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "page_size": 10,
  "sort": [
    {
      "field": "SORT_FIELD_HASHRATE",
      "direction": "SORT_DIRECTION_DESC"
    }
  ]
}

### Get miner state counts
POST {{host}}/fleetmanagement.v1.FleetManagementService/GetMinerStateCounts
Content-Type: application/json
Cookie: {{session_cookie}}

{}

### Get miner pool assignments
POST {{host}}/fleetmanagement.v1.FleetManagementService/GetMinerPoolAssignments
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_identifier": "TODO_REPLACE_WITH_DEVICE_ID"
}

### Get miner cooling mode
POST {{host}}/fleetmanagement.v1.FleetManagementService/GetMinerCoolingMode
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_identifier": "TODO_REPLACE_WITH_DEVICE_ID"
}

### Delete miners (by device list)
POST {{host}}/fleetmanagement.v1.FleetManagementService/DeleteMiners
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "device_selector": {
    "include_devices": {
      "device_identifiers": ["TODO_REPLACE_WITH_DEVICE_ID"]
    }
  }
}

### Get miner model groups
POST {{host}}/fleetmanagement.v1.FleetManagementService/GetMinerModelGroups
Content-Type: application/json
Cookie: {{session_cookie}}

{}
