set dotenv-load
set export

# list available recipies 
default:
  just --list
  
# lint project files
lint:
  golangci-lint run -c .golangci.yaml

# build fleet project
build-all:
    go build -v ./...

# install fleet
install:
    go install -v ./cmd/fleetd

# build plugins (called from root justfile)
_build-plugins:
  #!/usr/bin/env bash
  set -euo pipefail
  cd .. && just build-plugins

# build plugins for Docker (Linux ARM64)
_build-plugins-docker:
  #!/usr/bin/env bash
  set -euo pipefail
  cd .. && just build-plugins-docker

# run local server in docker compose with watch enabled on the fleet service
dev: _build-plugins-docker start
  docker compose up --watch fleet-api

# start services in docker compose 
start:
  docker compose up --wait

# stop services in docker
stop:
  docker compose down

# run all tests (DB_PASSWORD defaults to 'fleet' for local/CI testing)
test:
    DB_PASSWORD="${DB_PASSWORD:-fleet}" go test ./... -skip ./generated/...

# run e2e plugin integration test
test-plugin-integration:
    go test -v -tags=e2e ./e2e -run TestPluginIntegration

# format project files
format:
  goimports -w .

# run all code gen tasks
gen: gen-db-queries gen-miner-protos gen-go

# generate query via sqlc 
gen-db-queries:
  sqlc generate
  goimports -w generated/sqlc

# generate miner protobuf code
gen-miner-protos:
  buf generate
  goimports -w generated/miner-api

# go generate, this will run all go:generate directives in the project
gen-go:
  go generate ./...

# start db (PostgreSQL via TimescaleDB)
db-up:
  docker compose up --wait timescaledb

# run a db migration
db-migrate:
  migrate -database "postgres://fleet:fleet@localhost:5432/fleet?sslmode=disable" -path migrations up

# stop the db
db-down:
  docker compose down timescaledb

# tear down the db by running down migrations
db-clean:
  migrate -database "postgres://fleet:fleet@localhost:5432/fleet?sslmode=disable" -path migrations down

# launch psql shell for interacting with the db started via db-up
db-shell:
  psql -h 127.0.0.1 -U fleet -d fleet

# create a new migration
new-migration name:
  migrate create -ext sql -dir migrations -seq {{name}}

# run the local server (requires env: use --dotenv-filename .env.local, create .env file, or set vars manually)
_run: db-up install
     ../.hermit/go/bin/fleetd

# seed telemetry data for dashboard testing (always clears old synthetic rows first)
# examples:
#   just seed-telemetry --days 10 --devices 3
#   just seed-telemetry --clean-up
#   just seed-telemetry --days 30 --outliers
seed-telemetry *args:
    go run ./devtools/seedtelemetry {{args}}

# restarts the docker compose services and wipes out all data
clean-build: _build-plugins-docker
    docker compose down --rmi all --volumes && docker compose up --build -d

# restart and rebuild fleet-api only
rebuild-fleet-api:
  docker compose up fleet-api -d --build --force-recreate

# Internal helper to build and execute miner-debug-cli with specified action
_miner-debug-exec miner_name action error_code index:
  #!/usr/bin/env bash
  set -euo pipefail
  GOOS=linux GOARCH=amd64 go build -o /tmp/miner-debug-cli-linux ./cmd/miner-debug-cli
  docker cp /tmp/miner-debug-cli-linux server-{{miner_name}}:/tmp/miner-debug-cli
  docker exec server-{{miner_name}} /tmp/miner-debug-cli -action {{action}} -error {{error_code}} -index {{index}}
  rm -f /tmp/miner-debug-cli-linux

# inject an error on a miner using the debug API (example: just miner-inject-error mms-1 PSU_ERROR_CODE_OVER_TEMPERATURE 1)
miner-inject-error miner_name error_code index="1":
  just _miner-debug-exec {{miner_name}} inject {{error_code}} {{index}}

# resolve an error on a miner using the debug API (example: just miner-resolve-error mms-1 PSU_ERROR_CODE_OVER_TEMPERATURE 1)
miner-resolve-error miner_name error_code index="1":
  just _miner-debug-exec {{miner_name}} resolve {{error_code}} {{index}}
