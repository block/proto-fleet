set dotenv-load

# list available recipies 
default:
  just --list
  
# lint project files
lint:
  golangci-lint run -c .golangci.yaml

# build fleet project
build-all:
    go build -v ./...

# install fleet
install:
    go install -v ./cmd/fleetd

# build plugins (called from root justfile)
_build-plugins:
  #!/usr/bin/env bash
  set -euo pipefail
  cd .. && just build-plugins

# build plugins for Docker (Linux ARM64)
_build-plugins-docker:
  #!/usr/bin/env bash
  set -euo pipefail
  cd .. && just build-plugins-docker

# run local server in docker compose with watch enabled on the fleet service
dev: _build-plugins start
  docker compose up --watch fleet-api

# start services in docker compose 
start:
  docker compose up --wait

# stop services in docker
stop:
  docker compose down

# run all tests
test:
    go test ./... -skip ./generated/...

# run e2e plugin integration test
test-plugin-integration:
    go test -v -tags=e2e ./e2e -run TestPluginIntegration

# format project files
format:
  goimports -w .

# run all code gen tasks
gen: gen-db-queries gen-miner-protos gen-go

# generate query via sqlc 
gen-db-queries:
  sqlc generate
  goimports -w generated/sqlc

# generate miner protobuf code
gen-miner-protos:
  buf generate
  goimports -w generated/miner-api

# go generate, this will run all go:generate directives in the project
gen-go:
  go generate ./...

# start db
db-up:
  docker compose up --wait mysql

# run a db migration
db-migrate:
  migrate -database mysql://root:@tcp/fleet -path migrations up

# stop the db
db-down:
  docker compose down mysql

# tear down the db by running down migrations
db-clean:
  migrate -database mysql://root:@tcp/fleet -path migrations down

# launch mysql shell for interacting with the db started via db-up
db-shell:
  mysql -h 127.0.0.1 -u root --database fleet

# create a new migration
new-migration name:
  migrate create -ext sql -dir migrations -seq {{name}}

# run the local server (requires env: use --dotenv-filename .env.local, create .env file, or set vars manually)
_run: db-up install
     ../.hermit/go/bin/fleetd

# restarts the docker compose services and wipes out all data
clean-build: _build-plugins-docker
    docker compose down --rmi all --volumes && docker compose up --build -d

# restart and rebuild fleet-api only
rebuild-fleet-api:
  docker compose up fleet-api -d --build --force-recreate
