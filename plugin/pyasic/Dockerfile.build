FROM python:3.13-alpine AS builder

RUN apk add --no-cache \
    gcc \
    musl-dev \
    libffi-dev \
    binutils

WORKDIR /build

COPY pyproject.toml ./
COPY main.py ./
COPY config.yaml ./
COPY pyasic_driver/ ./pyasic_driver/

RUN pip install --no-cache-dir . pyinstaller

RUN pyinstaller \
    --onefile \
    --name pyasic-plugin \
    --hidden-import pyasic \
    --hidden-import yaml \
    main.py

FROM scratch AS export
COPY --from=builder /build/dist/pyasic-plugin /pyasic-plugin
