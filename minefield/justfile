# Minefield build commands

# Default recipe
default: build

# Generate Go definitions from Rust source
gen:
	@echo "Generating error definitions from Rust source..."
	go run ./cmd/generate -input ../miner-firmware/crates/miner_utils/src/error_details.rs
	@echo "Generated definitions_generated.go"

# Install web dependencies
web-install:
	@echo "Installing web dependencies..."
	cd web && npm install

# Build web client
web-build: web-install
	@echo "Building web client..."
	cd web && npm run build

# Run web client in dev mode
web-dev:
	cd web && npm run dev

# Build all binaries (with code generation)
build: gen
	@echo "Building minefield proxy..."
	go build -o bin/minefield ./cmd/minefield
	@echo "Building minefield CLI..."
	go build -o bin/minefield-cli ./cmd/minefield-cli
	@echo "Build complete!"

# Build everything including web
build-all: build web-build

# Run the proxy server (requires PROXY_URL env var)
run: build
	./bin/minefield

# Run with a specific target
run-with-target target: build
	./bin/minefield -target {{target}} -verbose

# Run against local Proto simulator
run-local: build
	./bin/minefield -target http://localhost:8000 -verbose

# Build and install binaries
install: build
	@echo "Installing binaries..."
	cp bin/minefield ~/go/bin/ || cp bin/minefield /usr/local/bin/
	cp bin/minefield-cli ~/go/bin/ || cp bin/minefield-cli /usr/local/bin/
	@echo "Installed!"

# Run tests
test:
	go test -v ./...

# Format code
fmt:
	go fmt ./...

# Lint code
lint:
	golangci-lint run ./...

# Clean build artifacts
clean:
	rm -rf bin/
	go clean

# Show available error definitions
show-errors: build
	./bin/minefield-cli definitions

# Trigger a test error
test-error: build
	./bin/minefield-cli trigger FanSlow -p fan_bay_index=1 -p fan_id=1 -p actual_rpm=1000

# List active errors
list: build
	./bin/minefield-cli list

# Clear all errors
clear: build
	./bin/minefield-cli clear --all

# Get dependencies
deps:
	go mod download
	go mod tidy

# Development mode - run with auto-rebuild (requires entr)
dev:
	find . -name "*.go" | entr -r just run-local