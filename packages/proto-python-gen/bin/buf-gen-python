#!/usr/bin/env bash
#
# buf-gen-python — Generate Python gRPC + protobuf stubs using Buf and grpc_tools.
#
# Usage:
#   buf-gen-python --output <dir> [--buf-config <dir>] [--path <subdir>] [--clean] [--help]
#
set -euo pipefail

# ── Defaults ──────────────────────────────────────────────────────────────────
OUTPUT_DIR=""
BUF_CONFIG_DIR="."
PROTO_PATH=""
CLEAN=false

# ── Locate package root (where setup.sh / .venv live) ────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PACKAGE_ROOT="${PROTO_PYTHON_GEN_ROOT:-$(cd "${SCRIPT_DIR}/.." && pwd)}"

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: buf-gen-python --output <dir> [OPTIONS]

Generate Python gRPC and protobuf stubs from a Buf-managed proto source.

Required:
  --output <dir>        Directory for generated Python files

Options:
  --buf-config <dir>    Directory containing buf.yaml (default: current dir)
  --path <subdir>       Only export protos under this subdirectory
  --clean               Remove output directory before generating
  --help                Show this help message

Environment:
  PROTO_PYTHON_GEN_ROOT   Override package root (default: auto-detected)
  PROTO_PYTHON_GEN_VENV   Override venv path (default: <package-root>/.venv)

Examples:
  buf-gen-python --output gen/python
  buf-gen-python --output gen/python --buf-config server --path sdk/v1
  buf-gen-python --output gen/python --clean
EOF
  exit 0
}

# ── Parse arguments ───────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --output)     OUTPUT_DIR="$2"; shift 2 ;;
    --buf-config) BUF_CONFIG_DIR="$2"; shift 2 ;;
    --path)       PROTO_PATH="$2"; shift 2 ;;
    --clean)      CLEAN=true; shift ;;
    --help)       usage ;;
    *)            echo "Error: unknown argument: $1" >&2; echo "Run with --help for usage." >&2; exit 1 ;;
  esac
done

if [[ -z "${OUTPUT_DIR}" ]]; then
  echo "Error: --output is required." >&2
  echo "Run with --help for usage." >&2
  exit 1
fi

# ── Locate Python venv ───────────────────────────────────────────────────────
VENV_DIR="${PROTO_PYTHON_GEN_VENV:-${PACKAGE_ROOT}/.venv}"

if [[ ! -d "${VENV_DIR}" ]]; then
  echo "Error: Python venv not found at ${VENV_DIR}" >&2
  echo "Run 'just setup' in ${PACKAGE_ROOT} first, or set PROTO_PYTHON_GEN_VENV." >&2
  exit 1
fi

PYTHON="${VENV_DIR}/bin/python"
if [[ ! -x "${PYTHON}" ]]; then
  echo "Error: Python not found in venv at ${PYTHON}" >&2
  exit 1
fi

# ── Verify tools ──────────────────────────────────────────────────────────────
if ! command -v buf &>/dev/null; then
  echo "Error: 'buf' not found on PATH." >&2
  echo "Install via Hermit: hermit install buf" >&2
  exit 1
fi

if ! "${PYTHON}" -c "import grpc_tools" &>/dev/null; then
  echo "Error: grpc_tools not importable from ${PYTHON}" >&2
  echo "Run 'just setup' in ${PACKAGE_ROOT} to install dependencies." >&2
  exit 1
fi

# ── Print versions ────────────────────────────────────────────────────────────
echo "=== buf-gen-python ==="
echo "  buf:         $(buf --version 2>&1)"
echo "  python:      $("${PYTHON}" --version 2>&1)"
echo "  grpcio-tools: $("${PYTHON}" -c "from importlib.metadata import version; print(version('grpcio-tools'))" 2>/dev/null || echo "unknown")"
echo "  protobuf:    $("${PYTHON}" -c "from importlib.metadata import version; print(version('protobuf'))" 2>/dev/null || echo "unknown")"
echo ""

# ── Clean output if requested ─────────────────────────────────────────────────
if [[ "${CLEAN}" == true ]] && [[ -d "${OUTPUT_DIR}" ]]; then
  echo "Cleaning output directory: ${OUTPUT_DIR}"
  rm -rf "${OUTPUT_DIR}"
fi

mkdir -p "${OUTPUT_DIR}"
OUTPUT_DIR="$(cd "${OUTPUT_DIR}" && pwd)"

# ── Export protos via buf ─────────────────────────────────────────────────────
TMPDIR="$(mktemp -d)"
trap 'rm -rf "${TMPDIR}"' EXIT

echo "Exporting protos from ${BUF_CONFIG_DIR} ..."

BUF_EXPORT_ARGS=("${BUF_CONFIG_DIR}" "--output" "${TMPDIR}")
if [[ -n "${PROTO_PATH}" ]]; then
  BUF_EXPORT_ARGS+=("--path" "${PROTO_PATH}")
fi

buf export "${BUF_EXPORT_ARGS[@]}"

# ── Discover proto files ──────────────────────────────────────────────────────
PROTO_FILES=()
while IFS= read -r -d '' f; do
  PROTO_FILES+=("$f")
done < <(find "${TMPDIR}" -name '*.proto' -print0)

if [[ ${#PROTO_FILES[@]} -eq 0 ]]; then
  echo "Error: no .proto files found after buf export." >&2
  exit 1
fi

echo "Found ${#PROTO_FILES[@]} proto file(s):"
for f in "${PROTO_FILES[@]}"; do
  echo "  - ${f#"${TMPDIR}"/}"
done
echo ""

# ── Locate grpc_tools well-known protos ───────────────────────────────────────
GRPC_TOOLS_PROTO_DIR="$("${PYTHON}" -c "
import os, grpc_tools
print(os.path.join(os.path.dirname(grpc_tools.__file__), '_proto'))
")"

# ── Generate Python stubs ─────────────────────────────────────────────────────
echo "Generating Python stubs into ${OUTPUT_DIR} ..."

"${PYTHON}" -m grpc_tools.protoc \
  "-I${TMPDIR}" \
  "-I${GRPC_TOOLS_PROTO_DIR}" \
  "--python_out=${OUTPUT_DIR}" \
  "--grpc_python_out=${OUTPUT_DIR}" \
  "${PROTO_FILES[@]}"

# ── Create __init__.py in every generated directory ───────────────────────────
while IFS= read -r -d '' dir; do
  init_file="${dir}/__init__.py"
  if [[ ! -f "${init_file}" ]]; then
    touch "${init_file}"
  fi
done < <(find "${OUTPUT_DIR}" -type d -print0)

# ── Report results ────────────────────────────────────────────────────────────
PB2_COUNT=$(find "${OUTPUT_DIR}" -name '*_pb2.py' | wc -l | tr -d ' ')
GRPC_COUNT=$(find "${OUTPUT_DIR}" -name '*_pb2_grpc.py' | wc -l | tr -d ' ')

echo ""
echo "Done! Generated:"
echo "  ${PB2_COUNT} *_pb2.py file(s)     (messages)"
echo "  ${GRPC_COUNT} *_pb2_grpc.py file(s) (services)"
echo "  Output: ${OUTPUT_DIR}"
