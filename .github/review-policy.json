{
  "enforce": false,
  "trusted_authors": [
    "@block/proto-fleet-dev",
    "ankitgoswami",
    "calebjohnston",
    "edgars-avotins",
    "flesher",
    "hadi-alam",
    "illegalprime",
    "jmarrxyz",
    "mcharles-square",
    "negarn",
    "rongxin-liu"
  ],
  "minimum_human_approvals": 1,
  "low_risk": {
    "max_changed_files": 10,
    "max_total_changes": 200,
    "minimum_ai_confidence": 0.85,
    "allowed_security_risks": [
      "NONE",
      "LOW"
    ],
    "required_checks": [
      "Gate",
      "security-review",
      "DCO Check",
      "Semgrep OSS",
      "zizmor"
    ],
      "deny_paths": [
        ".github/**",
        ".dockerignore",
        "CODEOWNERS",
        "buf.gen.yaml",
        "buf.yaml",
        "bin/**",
        "hermit-packages/**",
        "go.work",
        "go.work.sum",
        "just/**",
        "justfile",
        "lefthook.yml",
        "scripts/**",
        "deployment-files/**",
      "server/**",
      "plugin/**",
      "proto/**",
      "proto-rig-api/**",
      "sdk/**",
      "packages/proto-python-gen/**",
      "**/generated/**",
      "**/*.pb.go",
      "**/*.pb.ts",
      "**/migrations/**",
      "**/package.json",
      "**/package-lock.json",
        "**/go.mod",
        "**/go.sum",
        "**/buf.gen.yaml",
        "**/buf.yaml",
        "**/.dockerignore",
        "**/Dockerfile",
        "**/Dockerfile.*",
        "**/docker-compose*.yml",
        "**/docker-compose*.yaml",
        "**/Cargo.toml",
        "**/Cargo.lock",
        "**/pyproject.toml",
      "**/requirements*.txt",
      "**/uv.lock"
    ]
  }
}
