{
  "enforce": false,
  "trusted_authors": [
    "@block/proto-fleet-dev",
    "ankitgoswami",
    "calebjohnston",
    "edgars-avotins",
    "flesher",
    "hadi-alam",
    "illegalprime",
    "jmarrxyz",
    "mcharles-square",
    "negarn",
    "rongxin-liu"
  ],
  "minimum_human_approvals": 1,
  "security_review_check": "security-review",
  "security_review_workflow_path": ".github/workflows/codex-security-review.yml",
  "security_review_artifact": "codex-security-review-result",
  "low_risk": {
    "max_changed_files": 10,
    "max_file_changes": 80,
    "max_total_changes": 200,
    "minimum_ai_confidence": 0.85,
    "allowed_security_risks": [
      "NONE",
      "LOW"
    ],
    "required_checks": [
      "Gate",
      "security-review",
      "DCO Check",
      "Semgrep OSS",
      "zizmor"
    ],
    "content_deny_added_patterns": [
      {
        "pattern": "^\\s*#!",
        "reason": "adds a script shebang"
      },
      {
        "pattern": "\\b(child_process\\.|execFile\\s*\\(|execSync\\s*\\(|spawnSync\\s*\\(|spawn\\s*\\(|exec\\s*\\(|subprocess\\.|os\\.system\\s*\\(|exec\\.Command\\s*\\(|Command::new\\s*\\()",
        "reason": "adds process execution or shell-out code"
      },
      {
        "pattern": "\\b(eval\\s*\\(|new Function\\s*\\()",
        "reason": "adds dynamic code execution"
      }
    ],
    "deny_paths": [
      ".claude/**",
      ".gitattributes",
      ".github/**",
      "CODEOWNERS",
      "Procfile",
      "bin/**",
      "deployment-files/**",
      "dev.sh",
      "go.work",
      "go.work.sum",
      "hermit-packages/**",
      "just/**",
      "justfile",
      "lefthook.yml",
      "packages/**",
      "renovate.json",
      "scripts/**",
      "server/**",
      "plugin/**",
      "proto/**",
      "proto-rig-api/**",
      "sdk/**",
      "**/generated/**",
      "**/*.pb.go",
      "**/*.pb.ts",
      "**/migrations/**",
      "**/package.json",
      "**/package-lock.json",
      "**/.dockerignore",
      "**/.npmrc",
      "**/buf.gen.yaml",
      "**/buf.lock",
      "**/buf.yaml",
      "**/Cargo.lock",
      "**/Cargo.toml",
      "**/Dockerfile",
      "**/Dockerfile.*",
      "**/docker-compose*.yaml",
      "**/docker-compose*.yml",
      "**/go.mod",
      "**/go.sum",
      "**/pyproject.toml",
      "**/requirements*.txt",
      "**/uv.lock"
    ]
  }
}
