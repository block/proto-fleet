# Host profile: max
# Dedicated server: 8+ cores, 32GB+ RAM, NVMe storage, 5000+ miners.
# Aggressive on performance AND durability: telemetry commits stay
# synchronous and checkpoint_timeout stays moderate to bound crash-recovery
# time. Selected via FLEET_PROFILE in the deployment .env; override any
# single key by setting it in .env (operator values win).
PG_SHARED_BUFFERS=8GB
PG_EFFECTIVE_CACHE_SIZE=24GB
PG_WORK_MEM=64MB
PG_MAINTENANCE_WORK_MEM=1GB
PG_WAL_BUFFERS=64MB
PG_MIN_WAL_SIZE=2GB
PG_MAX_WAL_SIZE=8GB
PG_CHECKPOINT_TIMEOUT=10min
PG_WAL_COMPRESSION=lz4
PG_EFFECTIVE_IO_CONCURRENCY=256
PG_TS_MAX_BACKGROUND_WORKERS=12
PG_MAX_WORKER_PROCESSES=23
PG_TEMP_FILE_LIMIT=8GB
PG_LOG_MIN_DURATION_STATEMENT=500
PG_SHM_SIZE=2gb
DB_MAX_OPEN_CONNS=150
TELEMETRY_CONCURRENCY_LIMIT=1000
FLEET_COMMAND_MAX_WORKERS=1000
