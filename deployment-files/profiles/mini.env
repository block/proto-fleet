# Host profile: mini
# Low-power host (Raspberry Pi class), <=4GB RAM, SD/USB storage, up to
# ~200 miners. Selected via FLEET_PROFILE in the deployment .env; override
# any single key by setting it in .env (operator values win).
PG_MAX_CONNECTIONS=100
PG_SHARED_BUFFERS=512MB
PG_EFFECTIVE_CACHE_SIZE=1536MB
PG_WORK_MEM=8MB
PG_MIN_WAL_SIZE=256MB
PG_MAX_WAL_SIZE=1GB
PG_CHECKPOINT_TIMEOUT=15min
PG_WAL_COMPRESSION=lz4
PG_RANDOM_PAGE_COST=2.0
PG_EFFECTIVE_IO_CONCURRENCY=4
PG_MAX_PARALLEL_WORKERS=2
PG_MAX_PARALLEL_WORKERS_PER_GATHER=1
PG_MAX_PARALLEL_MAINTENANCE_WORKERS=1
PG_TS_MAX_BACKGROUND_WORKERS=4
PG_MAX_WORKER_PROCESSES=9
PG_TEMP_FILE_LIMIT=512MB
PG_TRACK_IO_TIMING=off
PG_LOG_MIN_DURATION_STATEMENT=2000
PG_SHM_SIZE=128mb
DB_MAX_OPEN_CONNS=40
DB_MAX_IDLE_CONNS=10
TELEMETRY_FETCH_INTERVAL=10s
TELEMETRY_STALENESS_THRESHOLD=30s
TELEMETRY_CONCURRENCY_LIMIT=100
TELEMETRY_METRIC_TIMEOUT=8s
TIMESCALEDB_QUERY_TIMEOUT=90s
TIMESCALEDB_MAX_TIME_SERIES_ROWS=25000
TIMESCALEDB_ASYNC_METRIC_COMMIT=true
FLEET_COMMAND_MAX_WORKERS=100
