# Copy this file to .env on each POC host and edit host-specific values.

HA_CLUSTER_NAME=proto-fleet-ha-poc
HA_NODE_NAME=fleet-a
HA_NODE_IP=10.0.0.11
HA_FLEET_A_IP=10.0.0.11
HA_FLEET_B_IP=10.0.0.12
HA_WITNESS_IP=10.0.0.13

# Port preset for running beside an existing Fleet instance on the same hosts.
# Use standard with 2379/2380/5432/8008/4080 only on dedicated hosts.
HA_POC_PORT_MODE=coexist
HA_ETCD_CLIENT_PORT=12379
HA_ETCD_PEER_PORT=12380
HA_POSTGRES_PORT=15432
HA_PATRONI_PORT=18008
HA_FAKE_FLEET_PORT=14080

# POC credentials. Change these before running on shared networks.
HA_POSTGRES_SUPERUSER_PASSWORD=change-me-postgres
HA_REPLICATION_USER=replicator
HA_REPLICATION_PASSWORD=change-me-replication
HA_REWIND_USER=rewind
HA_REWIND_PASSWORD=change-me-rewind

# The fake Fleet app defaults to the maintenance DB to avoid Fleet migrations.
HA_POC_DB_DSN='postgres://postgres:change-me-postgres@10.0.0.11:15432,10.0.0.12:15432/postgres?sslmode=disable&target_session_attrs=read-write'
HA_POC_HTTP_ADDR=0.0.0.0:14080
HA_POC_LEASE_TTL=6s
HA_POC_RENEW_INTERVAL=2s
HA_POC_ACQUIRE_INTERVAL=1s
HA_POC_HEARTBEAT_INTERVAL=1s
HA_POC_REQUIRE_MULTI_HOST_DSN=true
# Optional. If set, /health/ha requires Authorization: Bearer <token>.
HA_POC_STATUS_TOKEN=

# keepalived is installed as a host service on fleet-a and fleet-b.
HA_VIP=10.0.0.50
HA_VIP_CIDR=10.0.0.50/24
HA_VIP_INTERFACE=eth0
HA_VIP_ROUTER_ID=74
HA_VIP_AUTH_PASS=protofleet
HA_KEEPALIVED_PRIORITY=100
HA_KEEPALIVED_PEER_IP=10.0.0.12

# Override only if testing alternate images.
HA_ETCD_IMAGE=quay.io/coreos/etcd:v3.6.5
