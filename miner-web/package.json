{
  "name": "miner-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:protoOS",
    "dev:protoOS": "vite --mode protoOS",
    "dev:protoFleet": "vite --mode protoFleet",
    "prebuild": "npm run lint",
    "build": "tsc && vite build --mode protoOS && vite build --mode protoFleet",
    "generate-api-types": "node ./scripts/generate_api_ts.mjs",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "precommit": "lint-staged",
    "preview:protoOS": "vite preview --mode protoOS",
    "preview:protoFleet": "vite preview --mode protoFleet",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "upload": "scp -Crp dist/* admin@$npm_config_host:/home/admin/"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "clsx": "2.1.1",
    "motion": "^12.0.5",
    "path": "0.12.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.0",
    "recharts": "2.13.3"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.2",
    "@eslint/js": "9.14.0",
    "@storybook/addon-actions": "8.4.2",
    "@storybook/addon-controls": "8.4.2",
    "@storybook/react": "8.4.2",
    "@storybook/react-vite": "8.4.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.13.0",
    "@typescript-eslint/parser": "8.13.0",
    "@vitejs/plugin-react": "4.3.3",
    "concurrently": "^9.1.2",
    "eslint": "9.14.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "eslint-plugin-storybook": "0.11.0",
    "globals": "15.12.0",
    "jsdom": "25.0.1",
    "postcss": "8.4.47",
    "storybook": "8.4.2",
    "storybook-dark-mode": "4.0.2",
    "swagger-typescript-api": "13.0.22",
    "tailwindcss": "^4.0.6",
    "typescript": "5.6.3",
    "vite": "5.4.14",
    "vitest": "2.1.4"
  },
  "overrides": {
    "eslint": "9.14.0"
  }
}
