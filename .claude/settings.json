{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git branch --show-current:*)",
      "Bash(git rev-parse --abbrev-ref HEAD:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/git-commit-guard.sh"
          }
        ]
      }
    ]
  }
}
